{
  "name": "kilimo-audit-system",
  "version": "1.0.0",
  "description": "Automated testing and audit system for KILIMO Agri-AI Suite",
  "type": "module",
  "main": "audit.js",
  "scripts": {
    "audit": "node audit.js",
    "audit:quick": "node audit.js --quick",
    "audit:headless": "node audit.js --headless",
    "audit:role": "node audit.js --role=smallholder_farmer",
    "audit:ci": "node audit.js --headless --quick"
  },
  "keywords": [
    "kilimo",
    "testing",
    "audit",
    "qa",
    "automation"
  ],
  "author": "CREOVA",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "puppeteer": "^21.6.1"
  },
  "devDependencies": {
    "nodemailer": "^6.9.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
