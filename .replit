modules = ["nodejs-20", "bash"]
run = "npm run dev & npx expo start --tunnel"

[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev & npx expo start --tunnel"

[workflows.workflow.metadata]
outputType = "mobile"

[[ports]]
localPort = 8081
externalPort = 19000

[[ports]]
localPort = 5173
externalPort = 80
