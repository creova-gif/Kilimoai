modules = ["nodejs-20", "bash"]
language = "javascript"
entrypoint = "App.js"
outputType = "mobile"

[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Mobile App"

[[workflows.workflow]]
name = "Mobile App"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run start:mobile & npx expo start --tunnel"

[workflows.workflow.metadata]
outputType = "mobile"
