{
  "expo": {
    "name": "KILIMO AI",
    "slug": "kilimo-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "kilimoai",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kilimo.ai",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.kilimo.ai",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2E7D32"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow KILIMO AI to access your camera to diagnose crop diseases."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow KILIMO AI to access your photos for crop diagnosis."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow KILIMO AI to access your location for local weather and market data."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "jaymafie",
    "extra": {
      "eas": {
        "projectId": "1ee34dcc-aa20-4f85-988c-466261953362"
      }
    }
  }
}
