# KILIMO AI — environment template. Copy to `.env` and fill in.
#
# NOTE: anything prefixed EXPO_PUBLIC_ is INLINED into the shipped JS bundle and
# is publicly readable in the APK. Only put non-secret, client-safe values here.
# Provider API keys (Gemini, OpenAI, Africa's Talking) are NOT client vars —
# they live as Supabase edge-function secrets (see bottom of this file).

# ── Client (safe to ship) ─────────────────────────────────────────────
# Supabase project URL + anon key. The anon key is designed to be public and is
# protected by Row Level Security — it is NOT a secret.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# OpenWeather (client-side weather lookups). Low-sensitivity but rate-limited;
# consider proxying server-side before scale.
EXPO_PUBLIC_OPENWEATHER_API_KEY=YOUR_OPENWEATHER_KEY

# ── Server-side secrets (DO NOT put in this client .env) ───────────────
# Set these on the Supabase edge functions instead, e.g.:
#   supabase secrets set OPENAI_API_KEY=sk-...
#   supabase secrets set AFRICAS_TALKING_API_KEY=...
#   supabase secrets set AFRICAS_TALKING_USERNAME=...
#   supabase secrets set AFRICAS_TALKING_SENDER_ID=...    # optional
#
# Consumed by:
#   supabase/functions/openai-proxy   → OPENAI_API_KEY
#   supabase/functions/rag-chat       → OPENAI_API_KEY
#   supabase/functions/process-notifications → OPENAI_API_KEY
#   supabase/functions/sms-send       → AFRICAS_TALKING_*
