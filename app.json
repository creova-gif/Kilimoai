{
  "expo": {
    "name": "Kilimo AI",
    "slug": "kilimo-ai",
    "owner": "jaymafie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jaymafie.kilimoai",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "KILIMO AI hutumia kamera kupiga picha za mimea kwa uchunguzi wa AI.",
        "NSPhotoLibraryUsageDescription": "KILIMO AI hutumia picha zako kuchanganua afya ya mazao.",
        "NSMicrophoneUsageDescription": "KILIMO AI hutumia kipaza sauti kwa amri za sauti kwa Sankofa AI."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.jaymafie.kilimoai",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ],
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "KILIMO AI hutumia picha zako kuchanganua afya ya mazao.",
          "cameraPermission": "KILIMO AI hutumia kamera kupiga picha za mimea kwa uchunguzi wa AI."
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo-google-fonts/inter/100Thin/Inter_100Thin.ttf",
            "node_modules/@expo-google-fonts/inter/200ExtraLight/Inter_200ExtraLight.ttf",
            "node_modules/@expo-google-fonts/inter/300Light/Inter_300Light.ttf",
            "node_modules/@expo-google-fonts/inter/400Regular/Inter_400Regular.ttf",
            "node_modules/@expo-google-fonts/inter/500Medium/Inter_500Medium.ttf",
            "node_modules/@expo-google-fonts/inter/600SemiBold/Inter_600SemiBold.ttf",
            "node_modules/@expo-google-fonts/inter/700Bold/Inter_700Bold.ttf",
            "node_modules/@expo-google-fonts/inter/800ExtraBold/Inter_800ExtraBold.ttf",
            "node_modules/@expo-google-fonts/inter/900Black/Inter_900Black.ttf"
          ]
        }
      ],
      "expo-audio"
    ],
    "scheme": "kilimoai",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1ee34dcc-aa20-4f85-988c-466261953362"
      }
    }
  }
}
