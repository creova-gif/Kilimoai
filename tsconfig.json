{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "motion/react": [
        "./shims/motion/index.tsx"
      ],
      "motion": [
        "./shims/motion/index.tsx"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "supabase/functions",
    "artifacts"
  ]
}
